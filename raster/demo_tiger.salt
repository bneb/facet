// Facet Tiger Demo — Progressive Visual Rendering
//
// Opens a 512x512 macOS window and renders the tiger scene
// one path at a time, creating a build-up animation suitable
// for screen capture / video export.
//
// Run:  cd user/facet && make demo-tiger

package main

import std.core.ptr.Ptr
import facet.raster

// ═══════════════════════════════════════════════════════════════
// FFI — libc + libm
// ═══════════════════════════════════════════════════════════════

extern fn malloc(size: i64) -> Ptr<u8>;
extern fn free(ptr: Ptr<u8>);

// ═══════════════════════════════════════════════════════════════
// FFI — Facet Window Bridge
// ═══════════════════════════════════════════════════════════════

extern fn facet_window_open(width: i32, height: i32, title_ptr: Ptr<u8>) -> i64;
extern fn facet_window_present(handle: i64, pixels: Ptr<u8>, width: i32, height: i32);
extern fn facet_window_poll_events(handle: i64) -> i32;
extern fn facet_window_close(handle: i64);
extern fn facet_window_sleep_ms(ms: i32);

// ═══════════════════════════════════════════════════════════════
// Window title helper
// ═══════════════════════════════════════════════════════════════

fn make_title() -> Ptr<u8> {
    // "Facet Tiger" = [70,97,99,101,116,32,84,105,103,101,114,0]
    let mem = malloc(12);
    mem.offset(0).write(70 as u8);   // F
    mem.offset(1).write(97 as u8);   // a
    mem.offset(2).write(99 as u8);   // c
    mem.offset(3).write(101 as u8);  // e
    mem.offset(4).write(116 as u8);  // t
    mem.offset(5).write(32 as u8);   // (space)
    mem.offset(6).write(84 as u8);   // T
    mem.offset(7).write(105 as u8);  // i
    mem.offset(8).write(103 as u8);  // g
    mem.offset(9).write(101 as u8);  // e
    mem.offset(10).write(114 as u8); // r
    mem.offset(11).write(0 as u8);   // \0
    return mem;
}

// ═══════════════════════════════════════════════════════════════
// Tiger Scene — Progressive Rendering
//
// Each draw_step_* function adds one or two paths to the canvas,
// presents the frame, and sleeps. This creates a build-up
// animation: paths appear one at a time.
// ═══════════════════════════════════════════════════════════════

fn draw_step_head(c: &mut Canvas) {
    let mut p = path_new();
    path_move_to(&mut p, 256.0, 60.0);
    path_cubic_to(&mut p, 380.0, 60.0, 460.0, 140.0, 460.0, 240.0);
    path_cubic_to(&mut p, 460.0, 300.0, 440.0, 360.0, 400.0, 400.0);
    path_cubic_to(&mut p, 370.0, 430.0, 320.0, 460.0, 256.0, 470.0);
    path_cubic_to(&mut p, 192.0, 460.0, 142.0, 430.0, 112.0, 400.0);
    path_cubic_to(&mut p, 72.0, 360.0, 52.0, 300.0, 52.0, 240.0);
    path_cubic_to(&mut p, 52.0, 140.0, 132.0, 60.0, 256.0, 60.0);
    path_close(&mut p);
    fill_path(c, &p, 240, 144, 48, 255);
    path_free(&mut p);
}

fn draw_step_ears(c: &mut Canvas) {
    // Left ear
    let mut p = path_new();
    path_move_to(&mut p, 120.0, 140.0);
    path_cubic_to(&mut p, 100.0, 80.0, 60.0, 30.0, 40.0, 20.0);
    path_cubic_to(&mut p, 20.0, 10.0, 30.0, 60.0, 50.0, 100.0);
    path_cubic_to(&mut p, 60.0, 120.0, 80.0, 150.0, 120.0, 160.0);
    path_close(&mut p);
    fill_path(c, &p, 240, 144, 48, 255);
    path_free(&mut p);

    // Right ear
    let mut p2 = path_new();
    path_move_to(&mut p2, 392.0, 140.0);
    path_cubic_to(&mut p2, 412.0, 80.0, 452.0, 30.0, 472.0, 20.0);
    path_cubic_to(&mut p2, 492.0, 10.0, 482.0, 60.0, 462.0, 100.0);
    path_cubic_to(&mut p2, 452.0, 120.0, 432.0, 150.0, 392.0, 160.0);
    path_close(&mut p2);
    fill_path(c, &p2, 240, 144, 48, 255);
    path_free(&mut p2);
}

