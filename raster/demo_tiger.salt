// ═══════════════════════════════════════════════════════════════
// Main — Progressive Demo Loop
// ═══════════════════════════════════════════════════════════════

fn main() -> i32 {
    println("=== Facet Tiger Demo ===");
    println("  Progressive rendering — capture this window!");

    let title = make_title();
    let handle = facet_window_open(512, 512, title);

    if handle == 0 {
        println("  ERROR: failed to open window");
        free(title);
        return 1;
    }

    let mut c = canvas_new(512, 512);

    // Dark background
    canvas_clear_u32(&mut c, 0x18182AFF);
    facet_window_present(handle, c.pixels, c.width, c.height);
    facet_window_sleep_ms(500);

    // Step 1: Head outline
    println("  [1/12] Head outline");
    draw_step_head(&mut c);
    facet_window_present(handle, c.pixels, c.width, c.height);
    facet_window_sleep_ms(200);

    // Step 2: Ears
    println("  [2/12] Ears");
    draw_step_ears(&mut c);
    facet_window_present(handle, c.pixels, c.width, c.height);
    facet_window_sleep_ms(200);

    // Step 3: Inner ears
    println("  [3/12] Inner ears");
    draw_step_inner_ears(&mut c);
    facet_window_present(handle, c.pixels, c.width, c.height);
    facet_window_sleep_ms(200);

    // Step 4: Forehead stripes
    println("  [4/12] Forehead stripes");
    draw_step_stripes_forehead(&mut c);
    facet_window_present(handle, c.pixels, c.width, c.height);
    facet_window_sleep_ms(200);

    // Step 5: Cheek stripes
    println("  [5/12] Cheek stripes");
    draw_step_stripes_cheeks(&mut c);
    facet_window_present(handle, c.pixels, c.width, c.height);
    facet_window_sleep_ms(200);

    // Step 6: Temple stripes
    println("  [6/12] Temple stripes");
    draw_step_stripes_temple(&mut c);
    facet_window_present(handle, c.pixels, c.width, c.height);
    facet_window_sleep_ms(200);

    // Step 7: Muzzle
    println("  [7/12] Muzzle");
    draw_step_muzzle(&mut c);
    facet_window_present(handle, c.pixels, c.width, c.height);
    facet_window_sleep_ms(200);

    // Step 8: Eyes
    println("  [8/12] Eyes");
    draw_step_eyes(&mut c);
    facet_window_present(handle, c.pixels, c.width, c.height);
    facet_window_sleep_ms(200);

    // Step 9: Pupils + highlights
    println("  [9/12] Pupils");
    draw_step_pupils(&mut c);
    facet_window_present(handle, c.pixels, c.width, c.height);
    facet_window_sleep_ms(200);

    // Step 10: Nose
    println("  [10/12] Nose");
    draw_step_nose(&mut c);
    facet_window_present(handle, c.pixels, c.width, c.height);
    facet_window_sleep_ms(200);

    // Step 11: Mouth
    println("  [11/12] Mouth");
    draw_step_mouth(&mut c);
    facet_window_present(handle, c.pixels, c.width, c.height);
    facet_window_sleep_ms(200);

    // Step 12: Whiskers
    println("  [12/12] Whiskers");
    draw_step_whiskers(&mut c);
    facet_window_present(handle, c.pixels, c.width, c.height);

    // Hold the final image for 3 seconds
    println("  Done — holding for 3 seconds...");
    facet_window_sleep_ms(3000);

    // Cleanup
    facet_window_close(handle);
    canvas_free(&mut c);
    free(title);

    println("=== Demo complete ===");
    return 0;
}
